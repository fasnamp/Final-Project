      <column caption='Sleep Quality Category' datatype='string' name='[Calculation_0330161000255488]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Sleep Duration]&gt;=8 THEN &quot;GOOD&quot;&#13;&#10;ELSEIF [Sleep Duration]&gt;=5 THEN &quot;AVERAGE&quot;&#13;&#10;ELSE &quot;POOR&quot;&#13;&#10;END' />
      </column>
      <column caption='Stress Category' datatype='string' name='[Calculation_0330161001971714]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Stress Level]&gt;=7 THEN &quot; High Stress&quot;&#13;&#10;ELSEIF [Stress Level]&gt;=4 THEN &quot;Moderate Stress&quot;&#13;&#10;ELSE &quot;Low Stress&quot;&#13;&#10;END' />
      </column>
